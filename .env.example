# Copy to .env and adjust. All values have sane defaults; nothing here is required
# to run the local (tiny) backend.

# --- Auth -------------------------------------------------------------------
# Static token protecting the API. If empty, auth is DISABLED (dev convenience).
TRANSCRIPTOR_API_TOKEN=

# --- Models -----------------------------------------------------------------
# Local runs the fast model (tiny). Remote runs the strong model on HF's
# serverless tier, which only serves the larger Whisper (large-v3).
TRANSCRIPTOR_MODEL_FAST=openai/whisper-tiny
TRANSCRIPTOR_MODEL_STRONG=openai/whisper-large-v3

# --- Hugging Face hosted backend (optional; leave blank to stay local) ------
# Create a free token at https://huggingface.co/settings/tokens
TRANSCRIPTOR_HF_TOKEN=

# --- Redis (Stage B; leave blank for in-process async) ----------------------
# When set, async jobs are queued in Redis and processed by separate worker
# processes (run `python -m app.worker.worker`). Sync mode stays in-process.
TRANSCRIPTOR_REDIS_URL=

# --- Shared inference server (optional; leave blank to load model in-process) -
# When set, local inference is delegated to a shared model-server over HTTP, so
# the model is loaded once (not once per worker). docker-compose sets this
# automatically. e.g. http://model-server:8001
TRANSCRIPTOR_MODEL_SERVER_URL=

# --- Chunking ---------------------------------------------------------------
TRANSCRIPTOR_CHUNK_SECONDS=20
TRANSCRIPTOR_CHUNK_OVERLAP_SECONDS=2

# --- Concurrency / admission control ----------------------------------------
# Max chunks transcribed at once (per process). Guards CPU/RAM; excess queues.
TRANSCRIPTOR_MAX_CONCURRENT_CHUNKS=4
# Cap on concurrent outbound calls to Hugging Face (rate-limit guard).
TRANSCRIPTOR_HOSTED_MAX_CONCURRENCY=4

# --- Behaviour --------------------------------------------------------------
# If a hosted request fails and local weights are available, fall back to local.
TRANSCRIPTOR_FALLBACK_TO_LOCAL=true
# Max upload size in megabytes.
TRANSCRIPTOR_MAX_UPLOAD_MB=200
